# Local DB identifiers stay on legacy names so existing dev volumes keep working after the CyOps rebrand.
POSTGRES_DB=cyclaw
POSTGRES_USER=cyclaw
POSTGRES_PASSWORD=cyclaw_password
DATABASE_URL=postgresql+psycopg://cyclaw:cyclaw_password@postgres:5432/cyclaw

BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
JWT_SECRET=change-me-in-production
SESSION_COOKIE_NAME=cyops_session
SESSION_COOKIE_SECURE=false
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
ENABLE_DEV_AUTH_MOCKS=true

X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8000/api/auth/x/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/discord/callback
ADMIN_X_USERNAMES=cyops_team
VOTE_RATE_LIMIT_PER_MINUTE=60

NEXT_PUBLIC_API_URL=http://localhost:8000
API_PROXY_URL=http://localhost:8000
NEXT_PUBLIC_ENABLE_DEV_AUTH_MOCKS=true

